importa * da translate
importa * da nio
importa * da nmath
importa * da nfs

fissa LIMIT = 200
erstelle counter = 0

// German function definition
funktion test_math(a, b) {
    creer val = a * b
    renvoyer val
}

// French function definition
fonction check_status(val) {
    si (val > LIMIT) {
        mostrar("Status: High")
        altfel {
            ausgeben("Status: Normal")
        }
    }
}

// Spanish and Italian mixed loop
funcao execute_loop() {
    mentre (counter < 10) {
        creaza result = test_math(counter, 25)
        check_status(result)
        
        se (result == LIMIT) {
            afiseaza("Exact limit reached!")
        }
        
        counter = counter + 1
    }
}

execute_loop()
