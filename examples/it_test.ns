importa italiano da translate
importa * da nio
importa * da nmath
importa * da nfs

fissa GLOBAL_LIMIT = 500
crea base_value = 100

funzione calcola_fattoriale(n) {
    se (n <= 1) {
        ritorna 1
    }
    ritorna n * calcola_fattoriale(n - 1)
}

funzione verifica_logica(x, y, z) {
    crea risultato = falso
    se ((x > y && y > z) || (x == base_value)) {
        risultato = vero
    } altrimenti {
        risultato = falso
    }
    ritorna risultato
}

funzione esegui_pipeline_complessa() {
    stampa("=== AVVIO PIPELINE ===")
    
    crea somma_matrice = 0
    crea i = 0
    mentre (i < 5) {
        crea j = 0
        mentre (j < 5) {
            crea valore_cella = calcola_fattoriale(i) + sen(j * 0.5)
            somma_matrice = somma_matrice + valore_cella
            
            se (valore_cella > GLOBAL_LIMIT) {
                stampa("Limite superato alla cella:", i, j, "Valore:", valore_cella)
            } altrimenti {
                crea controllo = verifica_logica(valore_cella, i, j)
                se (controllo) {
                    stampa("Logica verificata alla cella:", i, j)
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    
    stampa("Somma Matrice:", somma_matrice)
    
    crea array_campione = [10, 20, 30, 40, 50]
    crea indice = 0
    mentre (indice < 5) {
        crea val = array_campione[indice]
        stampa("Valore dell array all indice:", indice, "e", val)
        indice = indice + 1
    }

    crea contenuto_file = leggi("data_source.txt")
    se (contenuto_file == nullo) {
        scrivi("data_source.txt", "INITIAL_DATA")
    } altrimenti {
        stampa("Dati caricati:", contenuto_file)
    }

    stampa("=== PIPELINE COMPLETATA ===")
}

esegui_pipeline_complessa()
