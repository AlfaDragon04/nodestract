importa italiano da translate
importa * da nio

funzione raddoppia(n) {
    ritorna n * 2
}

crea errore_rilevato = falso
prova {
    crea ris = raddoppia("cane")
} cattura (e) {
    errore_rilevato = vero
}

se (errore_rilevato == vero) {
    stampa("Wrong type handling OK")
} altrimenti {
    stampa("FAIL: raddoppia(cane) non ha generato eccezione")
}
