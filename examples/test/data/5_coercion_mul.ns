importa italiano da translate
importa * da nio

crea errore_rilevato = falso
prova {
    crea x = 1
    crea y = x * "pesci"
} cattura (e) {
    errore_rilevato = vero
}

se (errore_rilevato == vero) {
    stampa("Coercion mul invalid OK")
} altrimenti {
    stampa("FAIL: 1 * pesci non ha generato eccezione")
}
